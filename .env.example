# Environment
NODE_ENV=development
# Next.js Public URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP contact form
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM='your-name' <no-reply@gmail.com>
AUTHOR_EMAIL=your-author@gmail.com
